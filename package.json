{
  "name": "dj-tracklist-detector",
  "version": "1.0.0",
  "description": "Detect songs from YouTube DJ sets with SoundCloud links",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.djdetector.app",
    "productName": "DJ Tracklist Detector",
    "files": [
      "**/*",
      "!node_modules/electron-builder/**",
      "!dist/**"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.music",
      "icon": "assets/icon.icns",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.0",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1"
  }
}
